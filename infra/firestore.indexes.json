{
  "_comment": "Belvedere Firestore composite indexes (Phase 1-B 末 / 2026-06-09)。packages/repo/src/firestore.ts の FsTicketRepo.list / FsAgentRunRepo.list / FsCeremonyHealthRepo.list が 2 つ以上の equality where を組み合わせる際に必要。クライアント側ソート/limit で orderBy 由来の index 要求は回避済。",
  "_deploy": "firebase deploy --only firestore:indexes --project belvedere-dev-atrium",
  "_note": "実機で FAILED_PRECONDITION が出るたびに Firebase Console の auto-create リンクを使う運用でも可。本ファイルは IaC 化と再現性のため宣言的に保持。",

  "indexes": [
    {
      "collectionGroup": "tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sprintId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "ritual", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "assigneeId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "tickets",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sprintId", "order": "ASCENDING" },
        { "fieldPath": "ritual", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "agentRuns",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "agentName", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "ceremonyHealth",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sprintId", "order": "ASCENDING" },
        { "fieldPath": "ritual", "order": "ASCENDING" }
      ]
    }
  ],

  "fieldOverrides": []
}
