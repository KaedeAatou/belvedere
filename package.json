{
  "name": "belvedere",
  "version": "0.0.1",
  "private": true,
  "description": "Belvedere — Scrum facilitation AI agent (DevOps × AI Agent Hackathon 2026)",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:cli": "pnpm --filter @belvedere/cli dev",
    "demo": "pnpm --filter @belvedere/cli demo",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter \"!@belvedere/e2e\" --if-present test",
    "test:e2e": "pnpm --filter @belvedere/e2e e2e",
    "test:all": "pnpm test && pnpm test:e2e",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,md}'"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
